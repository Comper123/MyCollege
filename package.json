    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mkcert": "^3.2.0",
    "next": "^16.2.3",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "postgres": "^3.4.9",
