{
  "name": "mycollege",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "devs": "node server.js",
    "dev:network": "next dev -H 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:update": "drizzle-kit generate && drizzle-kit migrate && drizzle-kit push",
    "create-admin": "npx tsx src/scripts/create-admin.ts",
    "db:create-views": "tsx ./scripts/create-views.ts",
    "db:drop-views": "tsx ./scripts/create-views.ts drop",
    "test": "jest",
    "test:report": "jest --coverage --coverageReporters=html --coverageReporters=text",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.27",
